  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && rimraf dist && node -e \"const fs = require('fs-extra'); fs.copySync('build', 'dist'); fs.copySync('src/server.js', './server.js');\" && tar -czf code.tar.gz --exclude=\"node_modules\" --exclude=\".git\" --exclude=\"code.tar.gz\" --exclude=\".env\" .",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "analyze": "source-map-explorer 'build/static/js/*.js'"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "react-scripts": "5.0.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "3.4.10"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
