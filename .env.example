# Database Mode: 'supabase' | 'appwrite' | 'standalone'
# - supabase: Use Supabase PostgreSQL (RLS)
# - appwrite: Use Appwrite BaaS (self-hosted or cloud)
# - standalone: Use localStorage mock (dev/testing only)
DATABASE_MODE=supabase

# ============================================
# Supabase Configuration (required when DATABASE_MODE=supabase)
# Get these from https://app.supabase.com → Project Settings → API
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Disable Supabase postinstall script (needed for Appwrite/Vercel builds)
SUPABASE_DISABLE_POSTINSTALL=1

# ============================================
# Appwrite Configuration (required when DATABASE_MODE=appwrite)
# Get these from https://cloud.appwrite.io → Project → Settings → API Keys
# ============================================
# APPWRITE_API_KEY is only needed for server-side scripts (db:setup, db:migrate).
# It should NOT be set in client-side production environment for security.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_DATABASE_ID=default

# VITE_ prefixed versions (Vite automatically loads these in both dev and build)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-appwrite-project-id
VITE_APPWRITE_DATABASE_ID=default

# Enable fallback during migration (optional)
# Set VITE_ENABLE_FALLBACK=true to allow fallback to secondary DB on errors
# Set DUAL_WRITE_MODE=true to write to both databases simultaneously during cutover
VITE_ENABLE_FALLBACK=false
DUAL_WRITE_MODE=false

# Groq Cloud API (server-side only - set in Vercel/Appwrite env)
# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Zai Legal LLM API (server-side only - set in Vercel/Appwrite env)
# Contact Zai for API access
ZAI_API_KEY=your_zai_api_key_here

# Sentry Error Tracking (optional but recommended)
SENTRY_DSN=your-sentry-dsn

# Google Analytics (optional)
GA_ID=G-XXXXXXXXXX

# Resend API Key for email (optional)
RESEND_API_KEY=your-resend-key

# Admin email for contact form
ADMIN_EMAIL=admin@yourdomain.com

# Application Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict

# License Management (TwB Security)
LICENSE_SERVER_URL=https://api.techwithbrands.com
LICENSE_PUBLIC_KEY=your-license-public-key
LICENSE_APP_SECRET=your-app-secret-here
ENABLE_OBFUSCATION=true
ENABLE_TAMPER_DETECTION=true
ENABLE_INTEGRITY_CHECK=true

# IP Protection Watermark
COMPANY_NAME=Tech with Brands
COMPANY_OWNER=Anthony Kerige (Tony Kamau)
APP_VERSION=2.0.0

# Payment Integration
MPESA_TILL_NUMBER=8352474
KCB_ACCOUNT_NUMBER=1261709403
