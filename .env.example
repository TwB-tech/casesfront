# AppWrite Configuration (CRA format - REACT_APP_ prefix required)
# Set to 'true' to use AppWrite backend, 'false' for standalone localStorage mode
REACT_APP_USE_APPWRITE=true

# AppWrite endpoint (default is cloud.appwrite.io)
REACT_APP_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# AppWrite project ID (get from your AppWrite console)
REACT_APP_APPWRITE_PROJECT_ID=your-project-id

# AppWrite database ID (default is 'main')
REACT_APP_APPWRITE_DATABASE_ID=main

# Sentry Error Tracking (optional but recommended)
REACT_APP_SENTRY_DSN=your-sentry-dsn

# Google Analytics (optional)
REACT_APP_GA_ID=G-XXXXXXXXXX

# Application Security
REACT_APP_SESSION_COOKIE_SECURE=true
REACT_APP_SESSION_COOKIE_SAMESITE=Strict
