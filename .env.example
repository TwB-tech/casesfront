# Database Mode: 'supabase' for PostgreSQL, 'standalone' for localStorage mock
# For production with Supabase, set to 'supabase'
DATABASE_MODE=supabase

# Supabase Configuration (required when DATABASE_MODE=supabase)
# Get these from your Supabase project settings (https://app.supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase: disable CLI download during build (Vercel/Appwrite compatibility)
SUPABASE_DISABLE_POSTINSTALL=1

# Groq Cloud API (server-side only - set in Vercel/Appwrite env)
# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Zai Legal LLM API (server-side only - set in Vercel/Appwrite env)
# Contact Zai for API access
ZAI_API_KEY=your_zai_api_key_here

# Sentry Error Tracking (optional but recommended)
SENTRY_DSN=your-sentry-dsn

# Google Analytics (optional)
GA_ID=G-XXXXXXXXXX

# Resend API Key for email (optional)
RESEND_API_KEY=your-resend-key

# Admin email for contact form
ADMIN_EMAIL=admin@yourdomain.com

# Application Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict

# License Management (TwB Security)
LICENSE_SERVER_URL=https://api.techwithbrands.com
LICENSE_PUBLIC_KEY=your-license-public-key
LICENSE_APP_SECRET=your-app-secret-here
ENABLE_OBFUSCATION=true
ENABLE_TAMPER_DETECTION=true
ENABLE_INTEGRITY_CHECK=true

# IP Protection Watermark
COMPANY_NAME=Tech with Brands
COMPANY_OWNER=Anthony Kerige (Tony Kamau)
APP_VERSION=2.0.0

# Payment Integration
MPESA_TILL_NUMBER=8352474
KCB_ACCOUNT_NUMBER=1261709403
